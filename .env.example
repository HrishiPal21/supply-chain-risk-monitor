# OpenAI
OPENAI_API_KEY=sk-...

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=supply-chain-risk
PINECONE_ENVIRONMENT=us-east-1

# NewsAPI
NEWS_API_KEY=...

# GCP Cloud SQL (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supply_chain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=...
CLOUD_SQL_CONNECTION_NAME=project:region:instance   # used on Cloud Run

# GCP Cloud Storage
GCS_BUCKET_NAME=supply-chain-risk-raw
GCP_PROJECT_ID=...

# Google Application Credentials (local dev — service account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp_service_account.json
